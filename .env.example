# --- LLM provider (leave OPENAI_API_KEY blank to use mock provider) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
# For Gemini, set DEFAULT_PROVIDER=gemini and DEFAULT_MODEL=gemini-1.5-flash

# --- Postgres ---
POSTGRES_USER=ollive
POSTGRES_PASSWORD=ollive
POSTGRES_DB=ollive
DATABASE_URL=postgresql+asyncpg://ollive:ollive@postgres:5432/ollive

# --- Redis (event bus) ---
REDIS_URL=redis://redis:6379/0
LOG_STREAM=inference_logs

# --- Service URLs ---
INGESTION_URL=http://ingestion-api:8002
CHATBOT_PORT=8001
INGESTION_PORT=8002

# --- App ---
CONTEXT_WINDOW_TURNS=10
STORE_RAW_CONTENT=true
PII_REDACT=true
